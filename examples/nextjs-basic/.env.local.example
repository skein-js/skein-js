# Only needed for the `agent` graph (the Gemini ReAct agent). The `echo` graph needs nothing.
# Get a Gemini Developer API key at https://aistudio.google.com/apikey, then copy this to .env.local.

GOOGLE_API_KEY=AIza...
# Optional — override the Gemini model used by the agent graph.
GOOGLE_MODEL=gemini-2.5-flash
