# The UI talks to this same app's /api route (same origin) — no server URL needed.
# Copy to .env.local.

# Which graph the chat UI talks to. `echo` is zero-setup; `agent` needs ANTHROPIC_API_KEY below.
NEXT_PUBLIC_SKEIN_ASSISTANT_ID=echo

# Only needed if you switch the assistant to `agent` (the Claude ReAct agent).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-5
