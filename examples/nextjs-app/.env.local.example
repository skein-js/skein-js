# The UI talks to this same app's /api route (same origin) — no server URL needed.
# The chat is wired to the Gemini `agent` graph, so a Gemini API key is required.
# Get one at https://aistudio.google.com/apikey, then copy this file to .env.local.

GOOGLE_API_KEY=AIza...
# Optional — override the Gemini model.
# GOOGLE_MODEL=gemini-2.5-flash
