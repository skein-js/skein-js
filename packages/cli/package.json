{
  "name": "skein-js",
  "version": "0.7.0",
  "description": "The skein-js CLI — a drop-in replacement for the LangGraph CLI (dev/up/build/dockerfile).",
  "license": "Apache-2.0",
  "author": "Maina Wycliffe <wmmaina7@gmail.com>",
  "homepage": "https://github.com/skein-js/skein-js/tree/main/packages/cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skein-js/skein-js.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/skein-js/skein-js/issues"
  },
  "keywords": [
    "typescript",
    "langgraph",
    "cli",
    "agent-protocol",
    "langgraph-cli",
    "self-hosted"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "skein": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@commander-js/extra-typings": "~13.1.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.4",
    "@skein-js/core": "workspace:*",
    "@skein-js/config": "workspace:*",
    "@skein-js/express": "workspace:*",
    "@skein-js/runtime": "workspace:*",
    "commander": "~13.1.0"
  },
  "optionalDependencies": {
    "vite": "^8.1.0"
  },
  "peerDependencies": {
    "@langchain/langgraph": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
