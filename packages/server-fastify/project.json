{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "server-fastify",
  "sourceRoot": "packages/server-fastify/src",
  "projectType": "library",
  "targets": {
    "build": {
      "command": "tsup src/index.ts --format esm --dts --clean",
      "options": {
        "cwd": "packages/server-fastify"
      }
    },
    "typecheck": {
      "command": "tsc --noEmit",
      "options": {
        "cwd": "packages/server-fastify"
      }
    },
    "test": {
      "command": "vitest run",
      "options": {
        "cwd": "packages/server-fastify"
      }
    }
  }
}
