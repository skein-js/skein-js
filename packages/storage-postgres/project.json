{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "storage-postgres",
  "sourceRoot": "packages/storage-postgres/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsup src/index.ts --format esm --dts --clean",
        "cwd": "packages/storage-postgres"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "packages/storage-postgres"
      }
    },
    "test-integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config vitest.integration.config.ts",
        "cwd": "packages/storage-postgres"
      }
    }
  }
}
