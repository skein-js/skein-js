{
  "name": "@skein-js/runtime",
  "version": "0.6.0",
  "description": "Assembles skein-js ProtocolDeps from langgraph.json + selected drivers (memory/Postgres/Redis).",
  "license": "Apache-2.0",
  "author": "Maina Wycliffe <wmmaina7@gmail.com>",
  "homepage": "https://github.com/mainawycliffe/skein-js/tree/main/packages/runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mainawycliffe/skein-js.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/mainawycliffe/skein-js/issues"
  },
  "keywords": [
    "typescript",
    "langgraph",
    "agent-protocol",
    "runtime",
    "postgres",
    "redis"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@skein-js/agent-protocol": "workspace:*",
    "@skein-js/config": "workspace:*",
    "@skein-js/express": "workspace:*",
    "@skein-js/redis": "workspace:*",
    "@skein-js/storage-memory": "workspace:*",
    "@skein-js/storage-postgres": "workspace:*",
    "cors": "^2.8.5"
  },
  "peerDependencies": {
    "@langchain/langgraph": "^1.4.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.4"
  },
  "devDependencies": {
    "@langchain/core": "^1.2.0",
    "@langchain/langgraph": "^1.4.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.4",
    "@skein-js/test-support": "workspace:*",
    "@types/cors": "^2.8.17"
  },
  "publishConfig": {
    "access": "public"
  }
}
