{
  "name": "@skein-js/server-kit",
  "version": "0.9.0",
  "description": "Shared, framework-agnostic building blocks for skein-js HTTP adapters — in-memory dev runtime, LangGraph dev-state import, and langgraph.json CORS mapping.",
  "license": "Apache-2.0",
  "author": "Maina Wycliffe <wmmaina7@gmail.com>",
  "homepage": "https://github.com/skein-js/skein-js/tree/main/packages/server-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skein-js/skein-js.git",
    "directory": "packages/server-kit"
  },
  "bugs": {
    "url": "https://github.com/skein-js/skein-js/issues"
  },
  "keywords": [
    "typescript",
    "langgraph",
    "agent-protocol",
    "adapter",
    "cors"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@skein-js/agent-protocol": "workspace:*",
    "@skein-js/config": "workspace:*",
    "@skein-js/core": "workspace:*",
    "@skein-js/storage-memory": "workspace:*",
    "cors": "^2.8.5",
    "superjson": "^2.2.6",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@langchain/langgraph": "^1.4.0"
  },
  "devDependencies": {
    "@langchain/core": "^1.2.0",
    "@langchain/langgraph": "^1.4.0",
    "@types/cors": "^2.8.17"
  },
  "publishConfig": {
    "access": "public"
  }
}
