{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    // NestJS uses legacy (experimental) decorators. `emitDecoratorMetadata` is deliberately NOT set:
    // this package's DI uses explicit `@Inject(TOKEN)` everywhere, so no design:paramtypes metadata
    // is needed — which keeps the tsup/esbuild build clean without an @swc/core dependency.
    "experimentalDecorators": true
  },
  "include": ["src/**/*.ts"]
}
