{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "declaration": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@skein-js/core": ["packages/core/src/index.ts"],
      "@skein-js/config": ["packages/config/src/index.ts"],
      "@skein-js/express": ["packages/server-express/src/index.ts"],
      "@skein-js/fastify": ["packages/server-fastify/src/index.ts"],
      "@skein-js/nestjs": ["packages/server-nestjs/src/index.ts"],
      "@skein-js/storage-memory": ["packages/storage-memory/src/index.ts"],
      "@skein-js/storage-postgres": ["packages/storage-postgres/src/index.ts"],
      "@skein-js/redis": ["packages/runtime-redis/src/index.ts"],
      "@skein-js/agent-protocol": ["packages/agent-protocol/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
